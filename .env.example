# Database Configuration
# For local development (SQLite):
# DATABASE_URL=sqlite:///./sp3.db

# For production (PostgreSQL on Railway/Fly.io):
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./sp3.db

# Email Configuration
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=sp3weekly@yourdomain.com
REPLY_TO=derek@yourdomain.com

# Admin Configuration
ADMIN_SECRET=your_secret_key_here_min_32_chars
ADMIN_EMAIL=derek@yourdomain.com

# Server Configuration
PORT=8082
HOST=0.0.0.0
ENVIRONMENT=development

# Newsletter Schedule (cron format - Friday 6 AM ET)
NEWSLETTER_SCHEDULE=0 6 * * 4
